{
  "name": "expenze",
  "version": "2.0.0",
  "description": "Personal banking statement analyzer",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx src/server/server.ts",
    "postinstall": "node scripts/postinstall.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.5.207"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.67.0",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-router-devtools": "^1.114.0",
    "@tanstack/router-plugin": "^1.114.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.4.1",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.5.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
