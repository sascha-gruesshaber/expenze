{
  "name": "expenze",
  "version": "2.0.0",
  "description": "Personal banking statement analyzer",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push --accept-data-loss && concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "prisma generate && prisma db push --accept-data-loss && tsx src/server/server.ts",
    "postinstall": "node scripts/postinstall.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.4",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@tanstack/ai": "^0.6.3",
    "@tanstack/ai-openai": "^0.6.0",
    "@tanstack/ai-react": "^0.6.4",
    "better-auth": "^1.5.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "prisma": "^7.4.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nivo/calendar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/sankey": "^0.99.0",
    "@nivo/treemap": "^0.99.0",
    "@tanstack/react-query": "^5.67.0",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-router-devtools": "^1.114.0",
    "@tanstack/router-plugin": "^1.114.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.4.1",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
